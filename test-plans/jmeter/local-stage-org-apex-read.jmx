        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET Lead Records" enabled="true">
          <stringProp name="HTTPSampler.path">/services/apexrest/TestCWSObject/Lead</stringProp>
