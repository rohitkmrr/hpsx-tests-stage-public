      <hashTree>
        <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="BeanShell Sampler" enabled="true">
          <stringProp name="BeanShellSampler.query">import java.io.LineNumberReader;
import java.lang.*;
import java.io.FileReader;
import java.io.File;
import java.util.ArrayList;
import java.util.List;


LineNumberReader lineReader = new LineNumberReader(new FileReader(new File(&quot;${USERNAME_FILE}&quot;)));
String line = null;
int userIndex = Integer.parseInt(vars.get(&quot;USER_INDEX&quot;));
int count = 1;
Map users = new HashMap();
while ((line = lineReader.readLine()) != null) {
 if (count &gt;= userIndex) {
 	String[] userLine = line.split(&quot;,&quot;);
	List user = new ArrayList();
	user.add(userLine[0]);
	user.add(userLine[1]);
	users.put(count, user);
 }
 count++;
}
props.put(&quot;users&quot;, users);
lineReader.close();</stringProp>
        </BeanShellSampler>
        <hashTree/>
      </hashTree>
