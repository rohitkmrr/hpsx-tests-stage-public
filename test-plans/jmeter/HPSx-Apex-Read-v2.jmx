      <JSR223Listener guiclass="TestBeanGUI" testclass="JSR223Listener" testname="Assertion Failure Listener" enabled="false">
        <stringProp name="scriptLanguage">java</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">if (Boolean.valueOf(vars.get(&quot;DEBUG&quot;))) {
    for (a: sampleResult.getAssertionResults()) {
        if (a.isError() || a.isFailure()) {
            log.error(Thread.currentThread().getName() + &quot;: User:&quot; + vars.get(&quot;USERNAME&quot;) + &quot;; &apos;&quot; + sampleResult.getSampleLabel() + &quot;&apos; assertion failed with message &apos;&quot; + a.getFailureMessage() + &quot;&apos; and ressponse code is &quot; + sampleResult.getResponseCode() + &quot; with response message: &apos;&quot; + sampleResult.getResponseDataAsString() + &quot;&apos;; sessionid:&quot; + vars.get(&quot;SESSIONID&quot;));
        }
    }
}</stringProp>
      </JSR223Listener>
      <hashTree/>
      <SetupThreadGroup guiclass="SetupThreadGroupGui" testclass="SetupThreadGroup" testname="setUp Thread Group" enabled="false">
        <intProp name="ThreadGroup.num_threads">1</intProp>
