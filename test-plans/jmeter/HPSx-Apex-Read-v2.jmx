              <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Get ${sobject} Ids" enabled="true">
                <stringProp name="HTTPSampler.path">/services/apexrest/TestCWSObject/${sobject}</stringProp>
                <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
                <stringProp name="HTTPSampler.method">GET</stringProp>
